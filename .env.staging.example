# Copy this file to .env.staging on EC2.
# Do not commit .env.staging. It is ignored by .gitignore.

# ---- TourAPI ----
TOURAPI_SERVICE_KEY=replace_me

# ---- Optional AI APIs ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- Optional external place APIs ----
KAKAO_REST_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ---- PostgreSQL ----
# For a DB running on the EC2 host from inside Docker, keep host.docker.internal.
# For a DB compose service, set DB_HOST to that service name.
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=travel_db
DB_USER=postgres
DB_PASSWORD=replace_me

# ---- Runtime ----
API_PORT=5000
FRONTEND_PORT=4175
